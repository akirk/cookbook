{
    "name": "akirk/cookbook",
    "description": "Cookbook - A WordPress app powered by WpApp",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4",
        "akirk/wp-app": "^1.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "Cookbook\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Alex Kirk"
        }
    ],
    "config": {
	    "autoloader-suffix": "Cookbook"
    },
    "scripts": {
        "test": "phpunit"
    }
}
